# ── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
LOG_LEVEL=info

# ── API Keys (comma-separated, for client → gateway auth) ────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=change-me-key-1,change-me-key-2

# ── Node config files ────────────────────────────────────────────────────────
NODES_CONFIG=nodes.yaml
MODELS_CONFIG=models.yaml

# ── Health check ─────────────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=15        # seconds between health checks
HEALTH_CHECK_FAILURES=2         # consecutive failures before marking degraded
HEALTH_CHECK_TIMEOUT=5          # per-request timeout in seconds

# ── SQLite ────────────────────────────────────────────────────────────────────
DATABASE_PATH=data/platform.db

# ── Auth / Rate limiting (Phase 3) ───────────────────────────────────────────
# Bootstrap keys from API_KEYS are auto-imported to the key store on first run
# with name "bootstrap-N" and no rate limit.
# Use POST /api/auth/keys to create named keys with per-key rate limits.
#
# Default rate limit applied to keys that have rate_limit_rpm = 0 in the DB:
# 0 means unlimited.  Set via PATCH /api/auth/keys/{name}/rate-limit to change
# a specific key at runtime without restarting.
DEFAULT_RATE_LIMIT_RPM=0
